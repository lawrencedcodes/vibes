generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  name         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  metrics      Metric[]
  journals     Journal[]
  goals        Goal[]
  lists        List[]
  projects     Project[]
  events       Event[]
  googleToken  GoogleToken?
  habits       Habit[]
  focusSessions FocusSession[]
  journalEntries JournalEntry[]
  countdowns    Countdown[]
  healthLogs    HealthLog[]
}

model Metric {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date              String   // YYYY-MM-DD
  sleepHours        Float?
  habitsCompleted   Int      @default(0)
  habitsTotal       Int      @default(6)
  productivityScore Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, date])
}

model Journal {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD
  title     String
  content   String
  wordCount Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Goal {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  targetDate  DateTime
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  habits      Habit[]
}

model List {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime @default(now())
  todos     Todo[]
}

model Todo {
  id          String   @id @default(uuid())
  listId      String
  list        List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  content     String
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  subtasks    Subtask[]
  focusSessions FocusSession[]
}

model Subtask {
  id          String   @id @default(uuid())
  todoId      String
  todo        Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)
  content     String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Project {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  createdAt   DateTime @default(now())
  lists       List[]
}

model Event {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  isAllDay      Boolean  @default(false)
  googleEventId String?  @unique
  createdAt     DateTime @default(now())
}

model GoogleToken {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Habit {
  id            String     @id @default(uuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  type          String     @default("BOOLEAN")
  dailyTarget   Int?
  currentStreak Int        @default(0)
  longestStreak Int        @default(0)
  routine       String     @default("ANYTIME")
  createdAt     DateTime   @default(now())
  logs          HabitLog[]
  goalId        String?
  goal          Goal?      @relation(fields: [goalId], references: [id], onDelete: SetNull)
}

model HabitLog {
  id          String   @id @default(uuid())
  date        DateTime
  isCompleted Boolean  @default(false)
  value       Int?
  habitId     String
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model FocusSession {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime?
  duration  Int       // total minutes
  status    String    @default("COMPLETED")
  todoId    String?
  todo      Todo?     @relation(fields: [todoId], references: [id], onDelete: SetNull)
}

model JournalEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  content   String
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model Countdown {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  targetDate DateTime
  createdAt  DateTime @default(now())
}

model HealthLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  sleepHours  Float    @default(0)
  waterIntake Int      @default(0)
  energyLevel Int      @default(5)
  createdAt   DateTime @default(now())

  @@unique([userId, date])
}


